{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node16",  // ← CHANGÉ : de "bundler" → "node16"
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "declaration": true,
    "composite": true,
    "declarationMap": true        // ← AJOUTÉ : aide IDE
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
